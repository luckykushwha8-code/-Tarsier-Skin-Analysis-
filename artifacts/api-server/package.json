{
  "name": "api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --outdir=dist --format=esm --external:pg",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
